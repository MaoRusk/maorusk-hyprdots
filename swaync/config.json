{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "right",
  "positionY": "top",
  "control-center-positionX": "left",
  "layer": "overlay",
  "cssPriority": "user",

  "control-center-width": 400,
  "control-center-height": 700,
  "control-center-margin-top": 1,
  "control-center-margin-right": 3,
  "control-center-margin-left": 1,

  "notification-window-width": 360,
  "notification-icon-size": 48,
  "notification-body-image-height": 100,
  "notification-body-image-width": 200,

  "timeout": 3,
  "timeout-low": 2,
  "timeout-critical": 0,

  "fit-to-screen": false,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "transition-time": 200,
  "hide-on-clear": true,
  "hide-on-action": true,
  "script-fail-notify": true,

  "widgets": [
    "dnd",
    "mpris",
    "title",
    "notifications"
  ],

  "widget-config": {
    "dnd": {
      "text": "Do not Disturb"
    },
    "title": {
      "text": "Notifications",
      "clear-all-button": false,
      "button-text": "Clear"
    },
    "mpris": {
      "image-size": 1,
      "image-radius": 2
    },
    "volume": {
      "label": ""
    },
    "buttons-grid": {
      "buttons-per-row": 4,
      "actions": [
        {
          "label": "",
          "command": "hyprlock"
        },
        {
          "label": "󰽥",
          "command": "systemctl suspend"
        },
        {
          "label": "",
          "command": "systemctl reboot"
        },
        {
          "label": "󰐥",
          "command": "systemctl poweroff"
        }
      ]
    }
  }
}